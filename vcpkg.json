{
    "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
    "name": "audio-player-x86",
    "version-string": "0.1.0",
    "description": "Windows WASAPI exclusive-mode hi-fi audio player",
    "homepage": "https://github.com/local/audio_player_x86",
    "supports": "windows",
    "dependencies": [],
    "features": {
        "decoders": {
            "description": "Full decoder set (FLAC/WAV/MP3/AAC/OGG/ALAC/APE)",
            "dependencies": [
                "libflac",
                "libsndfile",
                {
                    "name": "ffmpeg",
                    "default-features": false,
                    "features": ["mp3lame", "fdk-aac", "vorbis", "opus"]
                },
                "taglib"
            ]
        },
        "opus": {
            "description": "Opus codec via opusfile + libopus",
            "dependencies": ["opusfile"]
        },
        "tests": {
            "description": "Unit tests via GoogleTest",
            "dependencies": ["gtest"]
        }
    },
    "default-features": []
}

