{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Seraph Audio Player",
  "version": "0.1.0",
  "identifier": "com.seraph.audio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Seraph Audio Player",
        "width": 1280,
        "height": 720,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "visible": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "© Seraph Audio",
    "category": "Music",
    "shortDescription": "Premium local HiFi audio player",
    "longDescription": "Seraph Audio Player — premium local HiFi audio player with WASAPI Exclusive mode, DSD support and bit-perfect playback."
  }
}
